<div class="page-container">
  <div class="page-header">
    <div>
      <p class="page-label">Projects</p>
      <h1 class="page-title">Create Project</h1>
      <p class="page-description">Add a new project and assign QA and developers.</p>
    </div>
  </div>

  <div class="project-form-grid">


<% if @project.errors[:description].present? %>
    <div class="field-error-text">
      <%= @project.errors.full_messages_for(:description).first %>
    </div>
  <% end %>


  <% if @project.errors[:name].present? %>
    <div class="field-error-text">
      <%= @project.errors.full_messages_for(:name).first %>
    </div>
  <% end %>

  <% if @project.errors[:image].present? %>
    <div class="field-error-text">
      <%= @project.errors.full_messages_for(:image).first %>
    </div>
  <% end %>


    <%= form_with model: @project, local: true, html: { multipart: true } do |form| %>
      <div class="form-card project-form-main">
        <div class="project-form-columns">
          <div class="project-form-fields">
            <div class="form-row">
              <%= form.label :name, class: "field-label" %>
              <%= form.text_field :name, class: "input-field" %>
            </div>

            <div class="form-row">
              <%= form.label :description, class: "field-label" %>
              <%= form.text_area :description, class: "input-field", rows: 4 %>
            </div>

            <div class="form-row">
              <p class="field-label">Assign to QA</p>
              <div class="multi-select" data-preview-role="qa">
                <details class="multi-select" role="listbox">
                  <summary class="multi-select-summary">Select QA</summary>
                  <div class="multi-select-panel">
                    <% @qas.each do |qa| %>
                      <label class="checkbox-row">
                        <%= check_box_tag "project[qa_user_ids][]", qa.id, false, multiple: true, id: nil, class: "selection-checkbox", data: { preview_role: "qa", preview_label: qa.name } %>
                        <span><%= qa.name %></span>
                      </label>
                    <% end %>
                  </div>
                </details>
              </div>
              <div class="selection-preview" data-preview-role="qa">
                <span class="selection-preview-label">Selected QA</span>
                <span class="selection-preview-values">None selected</span>
              </div>
            </div>

            <div class="form-row">
              <p class="field-label">Select Developers</p>
              <div class="multi-select" data-preview-role="developer">
                <details class="multi-select" role="listbox">
                  <summary class="multi-select-summary">Select Developers</summary>
                  <div class="multi-select-panel">
                    <% @developers.each do |developer| %>
                      <label class="checkbox-row">
                        <%= check_box_tag "project[developer_user_ids][]", developer.id, false, multiple: true, id: nil, class: "selection-checkbox", data: { preview_role: "developer", preview_label: developer.name } %>
                        <span><%= developer.name %></span>
                      </label>
                    <% end %>
                  </div>
                </details>
              </div>
              <div class="selection-preview" data-preview-role="developer">
                <span class="selection-preview-label">Selected Developers</span>
                <span class="selection-preview-values">None selected</span>
              </div>
            </div>
          </div>

          <aside class="project-form-sidebar">
            <div class="upload-card">
              <label for="project_image" class="upload-target">
                <% if @project.image.attached? %>
                  <%= image_tag @project.image, alt: @project.name.presence || "Project logo", class: "upload-preview" %>
                <% else %>
                  <div class="upload-placeholder">
                    <div class="upload-icon">+</div>
                    <p class="upload-title">Upload logo</p>
                    <p class="upload-hint">PNG, JPG</p>
                  </div>
                <% end %>
              </label>
              <%= form.file_field :image, id: "project_image", accept: "image/png,image/jpeg,image", class: "upload-input" %>
            </div>
          </aside>
        </div>

        <div class="actions-row">
          <%= form.submit "Create Project", class: "button button-primary" %>
          <%= link_to "Cancel", projects_path, class: "button button-secondary" %>
        </div>
      </div>
    <% end %>
  </div>
</div>
