<h1>Create Project</h1>

<%= form_with model: @project do |form| %>

  <div>
    <%= form.label :name %>
    <%= form.text_field :name %>
  </div>

  <div>
    <%= form.label :description %>
    <%= form.text_area :description %>
  </div>

  <% if false %>
    <h3>Select QA</h3>

    <%= form.collection_check_boxes(
          :user_ids,
          @qas,
          :id,
          :name
        ) do |box| %>

      <div>
        <%= box.check_box %>
        <%= box.label %>
      </div>

    <% end %>
  <% end %>


  <% if false %>
    <h3>Select Developers</h3>

    <%= form.collection_check_boxes(
          :user_ids,
          @developers,
          :id,
          :name
        ) do |box| %>

      <div>
        <%= box.check_box %>
        <%= box.label %>
      </div>

    <% end %>
  <% end %>

  <div>
    <%= form.submit "Create Project" %>
  </div>

<% end %>
