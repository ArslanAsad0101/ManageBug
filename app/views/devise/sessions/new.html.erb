<!-- app/views/devise/sessions/new.html.erb -->
<div class="auth-page">
  <div class="auth-panel auth-panel-dark">
    <div class="auth-preview">
      <div class="preview-box">
        <%= image_tag "Left.png", alt: "ManageBug preview", class: "preview-image" %>
      </div>
    </div>
  </div>

  <div class="auth-panel auth-panel-light">
    <div class="auth-panel-top-link">
      <span>Need an account?</span>
      <%= link_to "Sign Up", new_user_registration_path, class: "auth-link" %>
    </div>

    <div class="auth-heading">Log In</div>
    <p class="auth-text">Please fill your information below</p>

    <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
      <div class="form-group">
        <%= f.label :email, "E-mail" %>
        <%= f.email_field :email, class: "form-control", autocomplete: "email" %>
      </div>

      <div class="form-group">
        <%= f.label :password, "Password" %>
        <%= f.password_field :password, class: "form-control", autocomplete: "current-password" %>
      </div>

      <div class="form-actions">
        <%= f.submit "Login", class: "button button-primary" %>
      </div>
    <% end %>
  </div>
</div>