<div class="page-container">
  <div class="page-header">
    <div>
      <p class="page-label">Project details</p>
      <h1 class="page-title"><%= @project.name %></h1>
    </div>
    <%= link_to "Back to Projects", projects_path, class: "button button-secondary" %>
  </div>

  <div class="project-detail-card">
    <div class="project-detail-grid">
      <div class="project-detail-main">
        <div class="project-detail-section">
          <p class="section-label">About this project</p>
          <p class="section-text"><%= @project.description.present? ? @project.description : "No description provided." %></p>
        </div>

        <div class="project-detail-section">
          <p class="section-label">Selected users</p>
          <% if @project.assigned_users.any? %>
            <% @project.assigned_users.group_by(&:role).each do |role, users| %>
              <div class="project-user-group">
                <p class="project-user-role"><%= role.to_s.titleize %></p>
                <ul class="project-user-list">
                  <% users.each do |user| %>
                    <li><strong><%= user.name %></strong> <span>(<%= user.email %>)</span></li>
                  <% end %>
                </ul>
              </div>
            <% end %>
          <% else %>
            <p class="section-text">No users have been assigned to this project yet.</p>
          <% end %>
        </div>
      </div>

      <% if @project.image.attached? %>
        <div class="project-detail-image">
          <%= image_tag @project.image, alt: @project.name, class: "project-image" %>
        </div>
      <% end %>
    </div>

    <div class="project-detail-card-footer">
      <div class="project-detail-actions">
        <% if can? :update, @project %>
          <%= link_to "Edit", edit_project_path(@project), class: "button button-primary" %>
        <% end %>
        <% if can? :destroy, @project %>
          <%= link_to "Delete", @project, data: { turbo_method: :delete, turbo_confirm: "Are you sure?" }, class: "button button-danger" %>
        <% end %>
      </div>
    </div>
  </div>
</div>

<div class="project-bugs-section">
  <div class="project-bugs-inner">
    <div class="page-header">
      <div>
        <p class="page-label">Project Bugs</p>
        <h2 class="page-title"><%= pluralize(@project.bugs.count, "Bug") %></h2>
      </div>

      <% if can? :create, Bug %>
        <%= link_to "New Bug", new_bug_path, class: "button button-primary" %>
      <% end %>
    </div>

    <% if @project.bugs.any? %>
      <%= render "bugs/grid", bugs: @project.bugs %>
    <% else %>
      <div class="info-card">
        <p>No bugs have been created for this project yet.</p>
      </div>
    <% end %>
  </div>
</div>




