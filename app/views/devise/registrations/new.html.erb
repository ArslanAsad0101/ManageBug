<!-- app/views/devise/registrations/new.html.erb -->
<div class="auth-page">
  <div class="auth-panel auth-panel-dark">
    <div class="auth-preview">
      <div class="preview-box">
        <%= image_tag "Left.png", alt: "ManageBug preview", class: "preview-image" %>
      </div>
    </div>
  </div>

  <div class="auth-panel auth-panel-light">
    <div class="auth-panel-top-link">
      <span>Already have an account?</span>
      <%= link_to "Login", new_user_session_path, class: "auth-link" %>
    </div>

    <div class="auth-heading">Sign Up</div>
    <p class="auth-text">Please fill your information below</p>

    <%= render 'devise/shared/error_messages', resource: resource %>

    <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
      <% selected_role = params[:role].presence || resource.role.presence || "developer" %>

      <div class="form-group">
        <%= f.label :name, "Name" %>
        <%= f.text_field :name, class: "form-control", autocomplete: "name" %>
      </div>

      <div class="form-group">
        <%= f.label :phone_number, "Mobile number" %>
        <%= f.telephone_field :phone_number, class: "form-control", autocomplete: "tel",
      inputmode: "numeric",
      pattern: "[0-9]*",
      maxlength: 15,
      placeholder: "Enter digits only" %>
      </div>

      <div class="form-group">
        <label>Role</label>
        <div class="form-control" style="background: #f8f9fa; border: 1px solid #dfe3e8; padding: 0.75rem 1rem;">You are signing up as <strong><%= selected_role.titleize %></strong></div>
        <%= f.hidden_field :role, value: selected_role %>
      </div>

      <div class="form-group">
        <%= f.label :email, "E-mail" %>
        <%= f.email_field :email, class: "form-control", autocomplete: "email" %>
      </div>

      <div class="form-group">
        <%= f.label :password, "Password" %>
        <%= f.password_field :password, class: "form-control", autocomplete: "new-password" %>
      </div>

      <div class="form-group">
        <%= f.label :password_confirmation, "Confirm Password" %>
        <%= f.password_field :password_confirmation, class: "form-control", autocomplete: "new-password" %>
      </div>

      <div class="form-actions">
        <%= f.submit "Sign Up", class: "button button-primary" %>
      </div>
    <% end %>
  </div>
</div>