<div class="page-container">
  <div class="page-header">
    <div>
      <p class="page-label">Bugs</p>
      <h1 class="page-title">All Bugs Listing</h1>
      <p class="page-description">
        <% if current_user.qa? %>
          These are the bugs you reported.
        <% elsif current_user.developer? %>
          These are the bugs assigned to you.
        <% else %>
          These are bugs from your managed projects.
        <% end %>
      </p>
    </div>

    <% if can? :create, Bug %>
      <%= link_to "Add New Bug", new_bug_path, class: "button button-primary" %>
    <% end %>
  </div>

  <div class="table-card">
    <table class="table-list">
      <thead>
        <tr>
          <th>Bug details</th>
          <th>Status</th>
          <th>Due date</th>
          <th>Assigned to</th>
          <th>Project</th>
          <th>Action</th>
        </tr>
      </thead>
      <tbody>
        <% @bugs.each do |bug| %>
    <tr onclick="window.location='<%= project_bug_path(bug.project, bug) %>';" style="cursor: pointer;">
            <td><%= bug.title %></td>
            <td><span class="status-badge status-<%= bug.status %>"><%= bug.status.titleize %></span></td>
            <td><%= bug.deadline.present? ? bug.deadline.strftime("%b %d, %Y") : "—" %></td>
            <td><%= bug.developer.name %></td>
            <td><%= bug.project.name %></td>
            <td onclick="event.stopPropagation();">
              <div class="action-dropdown">
                <button class="action-menu-btn">⋮</button>
                <div class="dropdown-menu">
                  <div class="dropdown-header">Change Status</div>
                  <%= form_with url: edit_project_bug_path(bug.project, bug), method: :patch, local: true, class: "status-form" do |form| %>
                    <% ["pending", "in_progress", "resolved", "closed"].each do |status| %>
                      <%= form.submit status.titleize, name: "bug[status]", value: status, class: "dropdown-item status-#{status}" %>
                    <% end %>
                  <% end %>
                  <div class="dropdown-divider"></div>
                  <%= link_to "Delete", project_bug_path(bug.project, bug), method: :delete, data: { confirm: "Are you sure?" }, class: "dropdown-item delete-item" %>
                </div>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
