<div class="page-container">
  <div class="page-header">
    <div>
      <p class="page-label">Bugs</p>
      <h1 class="page-title">Create New Bug</h1>
      <p class="page-description">Add the bug details first, then choose the developer for the selected project.</p>
    </div>
    <%= link_to "Back to Bugs", bugs_path, class: "button button-secondary" %>
  </div>

  <% if @projects.empty? %>
    <div class="info-card">
      <p>You do not have any assigned projects yet. Please ask your manager to assign a project before creating a bug.</p>
    </div>
  <% else %>
    <div class="form-card">
      <% if @step == "select_developer" %>
        <h2 class="page-title" style="font-size: 1.25rem; margin-bottom: 1rem;">Step 2: Select a developer</h2>

        <%= form_with model: @bug,
            url: bugs_path,
            local: true,
            html: { id: "new-bug-form", multipart: true } do |form| %>

          <%= form.hidden_field :project_id %>
          <%= form.hidden_field :title %>
          <%= form.hidden_field :description %>
          <%= form.hidden_field :deadline %>
          <%= form.hidden_field :bug_type %>
          <%= form.hidden_field :status, value: "pending" %>

          <div class="form-row">
            <%= form.label :developer_id, "Developer", class: "field-label" %>
            <%= form.collection_select :developer_id,
                @developers,
                :id,
                :name,
                { prompt: "Select developer" },
                { class: "input-field" } %>
          </div>

          <div class="actions-row">
            <%= link_to "Back", new_bug_path, class: "button button-secondary" %>
            <%= form.submit "Create Bug", class: "button button-primary" %>
          </div>
        <% end %>
      <% else %>
        <h2 class="page-title" style="font-size: 1.25rem; margin-bottom: 1rem;">Step 1: Bug details</h2>

        <%= form_with model: @bug,
            url: new_bug_path,
            scope: :bug,
            method: :get,
            local: true,
            html: { id: "bug-details-form" } do |form| %>

          <%= hidden_field_tag :step, "select_developer" %>

          <div class="form-row">
            <%= form.label :project_id, "Project", class: "field-label" %>
            <%= form.collection_select :project_id,
                @projects,
                :id,
                :name,
                { prompt: "Select a project" },
                { class: "input-field" } %>
          </div>

          <div class="form-row">
            <%= form.label :title, class: "field-label" %>
            <%= form.text_field :title, class: "input-field" %>
          </div>

          <div class="form-row">
            <%= form.label :description, class: "field-label" %>
            <%= form.text_area :description, class: "input-field", rows: 4 %>
          </div>

          <div class="form-row form-row-split">
            <div>
              <%= form.label :deadline, class: "field-label" %>
              <%= form.date_field :deadline, class: "input-field" %>
            </div>
            <div>
              <%= form.label :bug_type, class: "field-label" %>
              <%= form.select :bug_type,
                  Bug.bug_types.keys.map { |type| [type.titleize, type] },
                  {},
                  class: "input-field" %>
            </div>
          </div>

          <%= form.hidden_field :status, value: "pending" %>

          <div class="actions-row">
            <%= form.submit "Next", class: "button button-primary" %>
          </div>
        <% end %>
      <% end %>
    </div>
  <% end %>
</div>
