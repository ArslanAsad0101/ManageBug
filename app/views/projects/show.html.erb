<div class="page-container">
  <div class="page-header">
    <div>
      <p class="page-label">Project details</p>
      <h1 class="page-title"><%= @project.name %></h1>
    </div>
    <%= link_to "Back to Projects", projects_path, class: "button button-secondary" %>
  </div>

  <div class="project-detail-card">
    <div class="project-detail-grid">
      <div class="project-detail-main">
        <div class="project-detail-section">
          <p class="section-label">Description</p>
          <p class="section-text"><%= @project.description.present? ? @project.description : "No description provided." %></p>
        </div>
      </div>

      <% if @project.image.attached? %>
        <div class="project-detail-image">
          <%= image_tag @project.image, alt: @project.name, class: "project-image" %>
        </div>
      <% end %>
    </div>
  </div>
</div>



<% if can? :update, @project %>
  <%= link_to "Edit",
      edit_project_path(@project),
      class: "button button-primary" %>
<% end %>
