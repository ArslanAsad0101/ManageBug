<div class="page-container">
  <!-- Header Section -->
  <div class="bug-show-header" style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 32px; border-bottom: 1px solid #ececee; padding-bottom: 24px;">
    <div style="flex: 1;">
      <h1 style="font-size: 28px; font-weight: 700; color: #1a1a1a; margin: 0 0 12px; line-height: 1.3;"><%= @bug.title %></h1>
      <p style="font-size: 13px; color: #9aa0a6; margin: 0;">Bug #<%= @bug.id %> in <strong><%= @bug.project.name %></strong></p>
    </div>
    <span class="status-badge status-<%= @bug.status %>" style="font-size: 13px; padding: 8px 16px; border-radius: 16px; background: #e8f5e9; color: #2e7d32; font-weight: 600;"><%= @bug.status_label %></span>
  </div>

  <!-- Main Content -->
  <div style="display: grid; grid-template-columns: 1fr 300px; gap: 32px; margin-bottom: 32px;">
    
    <!-- Details Panel -->
    <div class="bug-details-main">
      <!-- Description -->
      <div style="background: #ffffff; border: 1px solid #ececee; border-radius: 8px; padding: 24px; margin-bottom: 24px;">
        <h3 style="font-size: 14px; font-weight: 600; color: #1a1a1a; margin: 0 0 16px; text-transform: uppercase; letter-spacing: 0.5px; color: #9aa0a6;">Description</h3>
        <p style="color: #4a4a4a; line-height: 1.6; margin: 0; white-space: pre-wrap; word-wrap: break-word;"><%= @bug.description %></p>
      </div>

      <!-- Details Grid -->
      <div style="background: #ffffff; border: 1px solid #ececee; border-radius: 8px; padding: 24px; display: grid; grid-template-columns: 1fr 1fr; gap: 32px;">
        <div>
          <h4 style="font-size: 12px; color: #9aa0a6; margin: 0 0 8px; font-weight: 600; text-transform: uppercase;">Type</h4>
          <p style="font-size: 15px; color: #1a1a1a; margin: 0; font-weight: 500;"><%= @bug.bug_type.titleize %></p>
        </div>
        <div>
          <h4 style="font-size: 12px; color: #9aa0a6; margin: 0 0 8px; font-weight: 600; text-transform: uppercase;">Created</h4>
          <p style="font-size: 15px; color: #1a1a1a; margin: 0; font-weight: 500;"><%= @bug.created_at.strftime('%b %d, %Y') %></p>
        </div>
        <div>
          <h4 style="font-size: 12px; color: #9aa0a6; margin: 0 0 8px; font-weight: 600; text-transform: uppercase;">Developer</h4>
          <p style="font-size: 15px; color: #1a1a1a; margin: 0; font-weight: 500;"><%= @bug.developer&.name || 'Unassigned' %></p>
        </div>
        <div>
          <h4 style="font-size: 12px; color: #9aa0a6; margin: 0 0 8px; font-weight: 600; text-transform: uppercase;">Reporter</h4>
          <p style="font-size: 15px; color: #1a1a1a; margin: 0; font-weight: 500;"><%= @bug.reporter.name %></p>
        </div>
      </div>
    </div>

    <!-- Sidebar -->
    <div style="display: flex; flex-direction: column; gap: 16px;">
      <!-- Status Card -->
      <div style="background: #ffffff; border: 1px solid #ececee; border-radius: 8px; padding: 16px;">
        <h4 style="font-size: 12px; color: #9aa0a6; margin: 0 0 12px; font-weight: 600; text-transform: uppercase;">Status</h4>
        <div style="display: flex; align-items: center; gap: 8px;">
          <span style="width: 8px; height: 8px; border-radius: 50%; background: #2e7d32;"></span>
          <span style="font-size: 14px; font-weight: 600; color: #1a1a1a;"><%= @bug.status_label %></span>
        </div>
      </div>

      <!-- Project Card -->
      <div style="background: #ffffff; border: 1px solid #ececee; border-radius: 8px; padding: 16px;">
        <h4 style="font-size: 12px; color: #9aa0a6; margin: 0 0 12px; font-weight: 600; text-transform: uppercase;">Project</h4>
        <p style="font-size: 14px; color: #1a1a1a; margin: 0; font-weight: 500;"><%= link_to @bug.project.name, project_path(@bug.project), style: "color: #2f6fed; text-decoration: none;" %></p>
      </div>

      <!-- Actions -->
      <div style="display: flex; flex-direction: column; gap: 8px; margin-top: 16px;">
        <% if (current_user.qa? && @bug.reporter_id == current_user.id) || (current_user.developer? && @bug.developer_id == current_user.id) %>
          <%= link_to "Edit Bug", edit_project_bug_path(@project, @bug), class: "button button-primary", style: "text-align: center; display: block; margin: 0;" %>
        <% end %>
        
        <% if can? :destroy, @bug %>
          <%= link_to "Delete Bug", [@project, @bug], method: :delete, data: { confirm: "Are you sure?" }, class: "button button-danger", style: "text-align: center; display: block; margin: 0; background: #dc2626; color: #fff;" %>
        <% end %>
        
        <%= link_to "← Back to Bugs", bugs_path, class: "button button-secondary", style: "text-align: center; display: block; margin: 0;" %>
      </div>
    </div>
  </div>
</div>

<style>
  .bug-show-header h1 {
    word-break: break-word;
  }

  .status-badge {
    display: inline-block;
    white-space: nowrap;
  }

  .button-danger {
    background: #dc2626;
    color: #fff;
  }

  .button-danger:hover {
    background: #b91c1c;
    color: #fff;
  }

  @media (max-width: 768px) {
    [style*="grid-template-columns: 1fr 300px"] {
      grid-template-columns: 1fr !important;
    }
    
    [style*="grid-template-columns: 1fr 1fr"] {
      grid-template-columns: 1fr !important;
    }
  }
</style>