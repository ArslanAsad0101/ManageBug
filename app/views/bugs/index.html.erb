<div class="page-container">
  <div class="page-header">
    <div>
      <p class="page-label">Bugs</p>
      <h1 class="page-title">All Bugs Listing</h1>
      <p class="page-description">
        <% if current_user.qa? %>
          These are the bugs you reported.
        <% elsif current_user.developer? %>
          These are the bugs assigned to you.
        <% else %>
          These are bugs from your managed projects.
        <% end %>
      </p>
    </div>

    <div class="header-right">
      <%= form_with url: bugs_path, method: :get, local: true, class: "search-bar" do |form| %>
        <%= form.search_field :search,
            value: params[:search],
            placeholder: "Search for Bugs here",
            class: "search-input" %>
      <% end %>

      <% if can? :create, Bug %>
        <%= link_to "+ Add New Bug", new_bug_path, class: "button button-primary" %>
      <% end %>
    </div>
  </div>

        <div class="view-toggle" style="display:flex;justify-content:flex-end;align-items:center;gap:8px;margin-bottom:12px;">
          <%= link_to "☰", bugs_path(search: params[:search], view: 'list'), 
              class: "button #{@view == 'list' ? 'active' : ''}", 
              title: "List view", 
              aria_pressed: @view == 'list' %>
          <%= link_to "▦", bugs_path(search: params[:search], view: 'grid'), 
              class: "button #{@view == 'grid' ? 'active' : ''}", 
              title: "Grid view", 
              aria_pressed: @view == 'grid' %>
        </div>


  <% if @view == 'list' %>
    <div class="table-card">
      <table class="table-list">
        <thead>
          <tr>
            <th>Bug details</th>
            <th>Status</th>
            <th>Due date</th>
            <th>Assigned to</th>
            <th>Project</th>
          </tr>
        </thead>
        <tbody>
          <% @bugs.each do |bug| %>
            <tr onclick="window.location='<%= project_bug_path(bug.project, bug) %>';" style="cursor: pointer;">
              <td><%= bug.title %></td>
              <td><span class="status-badge status-<%= bug.status %>"><%= bug.status_label %></span></td>
              <td><%= bug.deadline.present? ? bug.deadline.strftime("%b %d, %Y") : "—" %></td>
              <td><%= bug.developer.name %></td>
              <td><%= bug.project.name %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div style="margin-top:16px;">
      <%= render partial: 'grid', locals: { bugs: @bugs } %>
    </div>
  <% end %>

</div>
